# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Smarty / Smart Starts
# ─────────────────────────────────────────────────────────────────────────────

# ── CRITIQUE : Ne jamais commiter ────────────────────────────────────────────
.env
.env.local
.env.production
.env.development
*.env
backend/.env
frontend/.env.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.log

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-error.log*

# ── Azure ─────────────────────────────────────────────────────────────────────
.azure/
*.azurecr.io

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Backup ────────────────────────────────────────────────────────────────────
*.bak
*.backup